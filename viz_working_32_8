        rain          = to_mm(hr_s[PRECIP_CH].numpy(), PRECIP_MEAN, PRECIP_STD)
        rain_sg, _, _ = clip_field(rain, lat_hr_full, lon_hr_full, clip_ext)
        mask_sg, _, _ = clip_field(sg_mask_full, lat_hr_full, lon_hr_full, clip_ext)

        rain_sg_masked = rain_sg[mask_sg]
        if rain_sg_masked.size == 0:
            continue
        v = float(np.max(rain_sg_masked))
        if v > WET_THRESH_MM:
            sg_candidates.append((v, dataset_idx))

    sg_candidates.sort(reverse=True)
    TOP_N       = 10
