def intensity_error(pred_mm, gt_mm, wet_thresh_mm):
    wet = gt_mm > wet_thresh_mm
    if wet.sum() == 0:
        return float("nan")
    gt_max   = float(np.max(gt_mm[wet]))
    pred_max = float(np.max(pred_mm[wet]))
    return 100.0 * abs(pred_max - gt_max) / (gt_max + 1e-6)


