def build_map_fig(gt, s2, extent, shp, world_gdf=None, title_tag="",
                  int_err_s2=None, grid_spacing=0.072, wet_thresh_mm=0.1):
    """
    Full domain map - Shows shapefiles normally (Singapore + countries)
    """
    err = s2 - gt
    rain_vmax = float(np.nanpercentile(np.concatenate([gt.ravel(), s2.ravel()]), 99))
    rain_vmax = max(rain_vmax, 0.1)
    
    err_flat = err.ravel()[np.isfinite(err.ravel())]
    pos_lim = float(np.nanpercentile(err_flat, 99))
    neg_lim = float(np.nanpercentile(err_flat, 1))
    err_lim = max(abs(pos_lim), abs(neg_lim), 0.05)

    cmap_r, norm_r, bounds_r = make_dynamic_cmap(rain_vmax, n_levels=9, kind="rain")
    cmap_e, norm_e, bounds_e = make_dynamic_cmap(err_lim, n_levels=9, kind="error")

    data = [gt, s2, err]
    cmaps = [cmap_r, cmap_r, cmap_e]
    norms = [norm_r, norm_r, norm_e]
    ttls = ["Ground Truth", "Model", "Error (Pred - GT)"]

    fig = plt.figure(figsize=(18, 5.8), facecolor="white")
    gs = gridspec.GridSpec(1, 3, figure=fig, wspace=0.08,
                           left=0.02, right=0.97, top=0.87, bottom=0.04)

    ims, axes = [], []
    for k in range(3):
        ax = fig.add_subplot(gs[k])
        im = ax.imshow(data[k], origin="lower", extent=extent,
                       cmap=cmaps[k], norm=norms[k], interpolation="bilinear")

        # World country borders (normal)
        if world_gdf is not None:
            world_gdf.boundary.plot(ax=ax, color="#000000", linewidth=1.5, 
                                   alpha=0.85, zorder=6)
        
        

        _pixel_grid(ax, data[k].shape, extent, color="gray")

        ax.set_title(ttls[k], color="black", fontsize=22, weight="bold", pad=8)
        ax.set_xticks([]); ax.set_yticks([])
        ax.set_xlim(extent[0], extent[1])
        ax.set_ylim(extent[2], extent[3])

        for sp in ax.spines.values():
            sp.set_edgecolor("black")

        ims.append(im)
        axes.append(ax)

    # Stats box
    wet_mask = gt > wet_thresh_mm
    pcc = compute_pcc(s2, gt)
    bias = float(np.nanmean(err[wet_mask])) if wet_mask.any() else 0.0
    rmse = float(np.sqrt(np.nanmean((err[wet_mask])**2))) if wet_mask.any() else 0.0

    lines = [f"PCC {pcc:.3f}", f"Bias {bias:+.2f} mm", f"RMSE {rmse:.2f} mm"]
    if int_err_s2 is not None:
        lines.append(f"IntErr {int_err_s2:.2f}%")

    axes[1].text(0.02, 0.03, "\n".join(lines),
                 transform=axes[1].transAxes, fontsize=19, color="black",
                 bbox=dict(fc="white", ec="gray", alpha=0.85, pad=4), va="bottom")

    # Colorbars
    cb1 = fig.colorbar(ims[0], ax=axes[:2], cmap=cmap_r, norm=norm_r,
                       fraction=0.018, pad=0.01, ticks=bounds_r, shrink=0.90)
    cb1.set_label("Precipitation (mm/day)", color="black", fontsize=22)
    cb1.ax.set_yticklabels([f"{b:.1f}" for b in bounds_r], color="black", fontsize=19)

    _discrete_cb(fig, axes[2], ims[2], cmap_e, norm_e, bounds_e, "Signed Error (mm)")

    fig.suptitle(f"Singapore Full Domain {title_tag}", 
                 color="black", fontsize=24, weight="bold", y=0.96)

    return fig


def build_sg_map_fig(gt, pred, extent, shp, world_gdf=None, title_tag=""):
    """
    Singapore-focused map - Shows shapefiles normally (Singapore + countries)
    """
    err = pred - gt
    rain_vmax = float(np.nanpercentile(np.concatenate([gt.ravel(), pred.ravel()]), 99))
    rain_vmax = max(rain_vmax, 1.0)

    err_flat = err.ravel()[np.isfinite(err.ravel())]
    pos_lim = float(np.nanpercentile(err_flat, 99))
    neg_lim = float(np.nanpercentile(err_flat, 1))
    err_lim = max(abs(pos_lim), abs(neg_lim), 0.05)

    cmap_r, norm_r, bounds_r = make_dynamic_cmap(rain_vmax, kind="rain")
    cmap_e, norm_e, bounds_e = make_dynamic_cmap(err_lim, kind="error")

    fig, axes = plt.subplots(1, 3, figsize=(15, 5), facecolor="white")
    fig.patch.set_facecolor("white")

    titles = ["Ground Truth", "Model", "Error (Pred - GT)"]
    data = [gt, pred, err]
    cmaps = [cmap_r, cmap_r, cmap_e]
    norms = [norm_r, norm_r, norm_e]

    for i, ax in enumerate(axes):
        ax.set_facecolor("white")
        im = ax.imshow(data[i], origin="lower", extent=extent,
                       cmap=cmaps[i], norm=norms[i], interpolation="bilinear")

        # World country borders (normal)
        if world_gdf is not None:
            world_gdf.boundary.plot(ax=ax, color="#000000", linewidth=1.5, 
                                   alpha=0.85, zorder=6)
        
        

        ax.set_title(titles[i], color="black", fontsize=22, weight="bold", pad=6)
        ax.set_xticks([]); ax.set_yticks([])
        ax.set_xlim(extent[0], extent[1])
        ax.set_ylim(extent[2], extent[3])

        fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)

    # Stats box
    wet_mask = gt > 0.1
    bias = float(np.nanmean(err[wet_mask])) if wet_mask.any() else 0.0
    rmse = float(np.sqrt(np.nanmean(err[wet_mask]**2))) if wet_mask.any() else 0.0
    pcc = compute_pcc(pred, gt)

    axes[2].text(0.02, 0.03,
                 f"Bias {bias:+.2f} mm\nRMSE {rmse:.2f} mm\nPCC {pcc:.3f}",
                 transform=axes[2].transAxes, fontsize=19, color="black",
                 bbox=dict(fc="white", ec="gray", alpha=0.85, pad=4), va="bottom")

    fig.suptitle(title_tag + " Singapore Region", fontsize=24, color="black", weight="bold")
    fig.tight_layout()

    return fig


# [C1] PSD: gt vs coarse LR upsampled input vs CorrDiff output
def build_psd_figure(gt_list, lr_list, s2_list):
    """
    Spatial PSD: Ground Truth (8 km) vs Coarse Input (32 km bilinear upsampled)
    vs CorrDiff output.

    Parameters
    ----------
    gt_list  : list of 2-D GT precipitation arrays
    lr_list  : list of 2-D coarse LR upsampled precipitation arrays  [C1]
    s2_list  : list of 2-D CorrDiff-predicted precipitation arrays
    """
    psd_gt = compute_mean_psd(gt_list)
    psd_lr = compute_mean_psd(lr_list)   # true coarse input [C1]
    psd_s2 = compute_mean_psd(s2_list)

    psd_gt /= psd_gt.sum() + 1e-8
    psd_lr /= psd_lr.sum() + 1e-8
    psd_s2 /= psd_s2.sum() + 1e-8

    freq = np.arange(1, len(psd_gt) + 1)

    fig, ax = plt.subplots(figsize=(8, 5))
    ax.plot(freq, psd_gt, linewidth=2.5, label="Ground Truth (8 km)")
    ax.plot(freq, psd_lr, linewidth=2,   linestyle="--",
            label="Coarse Input (32 km bilinear)")   # [C1]
    ax.plot(freq, psd_s2, linewidth=2,   label="Model Output")
    ax.set_xscale("log")
    ax.set_yscale("log")
    ax.set_xlabel("Spatial Frequency (Radial)")
    ax.set_ylabel("Normalised Power Spectral Density")
    ax.set_title("Spatial Power Spectrum  Resolution Recovery")
    ax.legend(frameon=False)
    ax.grid(alpha=0.2)
    return fig


# [C2] PCC figures: pure gaussian_kde � no histogram fallback
def _build_pcc_fig(pcc_values, title, xlabel, pcc_floor=0.6):
    """
    KDE-based PDF of PCC values (values below pcc_floor are filtered out).

    Parameters
    ----------
    pcc_values : array-like of PCC scores in [0, 1]
    title      : axes title string
    xlabel     : x-axis label string
    pcc_floor  : filter threshold (default 0.6)
    """
    fig, ax = plt.subplots(figsize=(8, 5))

    arr = np.asarray(pcc_values, dtype=float)
    arr = arr[np.isfinite(arr) & (arr >= pcc_floor)]

    if len(arr) < 2:
        ax.text(0.5, 0.5, "Insufficient data after filtering",
                ha="center", va="center", transform=ax.transAxes)
        ax.set_title(title)
        return fig

    x   = np.linspace(pcc_floor, 1.0, 400)
    kde = gaussian_kde(arr)          # [C2] KDE only
    ax.plot(x, kde(x), linewidth=2, label="Model")
    ax.fill_between(x, kde(x), alpha=0.15)

    median = float(np.median(arr))
    ax.axvline(median, linestyle=":", linewidth=2,
               label=f"Median = {median:.3f}")

    ax.set_xlim(pcc_floor, 1.0)
    ax.set_xlabel(xlabel)
    ax.set_ylabel("Probability Density")
    ax.set_title(title)
    ax.legend()
    ax.grid(True, alpha=0.3)
    return fig


def build_pcc_figure(pcc_s2):
    """PCC distribution over full domain."""
    return _build_pcc_fig(
        pcc_s2,
        title="PCC compared with GT (full domain)",
        xlabel=f"PCC (= 0.6)",
    )


def build_pcc_sg_figure(pcc_s2_sg):
    """PCC distribution over Singapore region."""
    return _build_pcc_fig(
        pcc_s2_sg,
        title="PCC compared with GT (Singapore region)",
        xlabel=f"PCC (Singapore region, = 0.6)",
    )


