        v = float(np.max(rain_sg)) if rain_sg.size > 0 else 0.0
        top_samples.append((v, FORCED_IDX))
        print(f" Force-added {FORCED_IDX}")

    print(f" Top {len(top_samples)} Singapore samples:")
    for rank, (val, idx) in enumerate(top_samples):
        print(f" #{rank+1} {idx_to_date(idx, time_array)}  SG_max={val:.2f} mm")

    clip_ext_sg = clip_ext

    # -- Map generation (Singapore focus) -------------------------------------
    for rank, (best_val, best_idx) in enumerate(top_samples):
        date_str = idx_to_date(best_idx, time_array)
