# Thresholds
WET_THRESH_LIN = 0.1      # mm/day
HEAVY_PCTILE   = 90       # percentile for "heavy" pixels
DRY_MARGIN     = 0.02     # mm/day ghost-rain threshold

# [F3] Loss ramp: wPCC term weight rises from 0 → WPCC_MAX over WPCC_RAMP epochs
# using a sigmoid schedule.  MSE weight falls correspondingly.
# This avoids the hard jump that caused nan at epoch 20.
WPCC_MAX  = 0.8           # max weight for (1 - wPCC) term
WPCC_RAMP = 300           # epochs to reach ~90% of WPCC_MAX
MSE_MIN   = 0.05          # floor for MSE weight (never goes below this)

# How often to save ensemble checkpoint
CKPT_SAVE_EVERY = 50

# ================================================================
# DDP
# ================================================================
def setup_ddp():
    rank = int(os.environ.get("RANK", 0))
    ws   = int(os.environ.get("WORLD_SIZE", 1))
    lr_  = int(os.environ.get("LOCAL_RANK", 0))
    if ws > 1:
        dist.init_process_group("nccl")
        torch.cuda.set_device(lr_)
    dev = torch.device(f"cuda:{lr_}" if torch.cuda.is_available() else "cpu")
    return rank, ws, lr_, dev

def is_main(r): return r == 0

def allreduce_mean(t, ws):
    if ws > 1 and dist.is_initialized():
        dist.all_reduce(t, op=dist.ReduceOp.SUM); t /= ws
    return t


# ================================================================
# [F3] SMOOTH LOSS SCHEDULE
# ================================================================

def loss_weights(ep: int):
    """
    Returns (w_mse, w_wpcc) that sum to 1.0, with w_wpcc rising smoothly
    via a sigmoid ramp centred at WPCC_RAMP / 2 epochs.

    epoch 0   : w_mse ≈ 1.0,  w_wpcc ≈ 0.0
    epoch 150 : w_mse ≈ 0.5,  w_wpcc ≈ 0.5 * WPCC_MAX  (mid-ramp)
    epoch 300+: w_mse ≈ MSE_MIN, w_wpcc ≈ WPCC_MAX
    """
    # Sigmoid centred at WPCC_RAMP/2, scaled so it reaches ~0.99 at WPCC_RAMP
    k = 10.0 / WPCC_RAMP   # steepness
    sigmoid = 1.0 / (1.0 + math.exp(-k * (ep - WPCC_RAMP / 2)))
    w_wpcc  = WPCC_MAX * sigmoid
    w_mse   = max(MSE_MIN, 1.0 - w_wpcc)
    return w_mse, w_wpcc


# ================================================================
# LOSS FUNCTIONS
# ================================================================

def mse_log1p(pred_log, target_log):
    return F.mse_loss(pred_log, target_log)


def wet_pixel_l1(pred_lin, target_lin):
    wet = target_lin > WET_THRESH_LIN
    if not wet.any():
        return pred_lin.new_tensor(0.0)
    return F.l1_loss(pred_lin[wet], target_lin[wet])


def heavy_rain_focal_mse(pred_lin, target_lin):
    wet_vals = target_lin[target_lin > WET_THRESH_LIN]
    if wet_vals.numel() < 10:
        return pred_lin.new_tensor(0.0)
    threshold = torch.quantile(wet_vals, HEAVY_PCTILE / 100.0)
    heavy = target_lin > threshold
    if not heavy.any():
        return pred_lin.new_tensor(0.0)
    return F.mse_loss(pred_lin[heavy], target_lin[heavy])


def dry_pixel_penalty(pred_lin, target_lin):
    dry = target_lin < WET_THRESH_LIN
    if not dry.any():
        return pred_lin.new_tensor(0.0)
    violation = (pred_lin[dry] - DRY_MARGIN).clamp(min=0.0)
    return (violation ** 2).mean() * 10.0


# ================================================================
# METRICS
# ================================================================

def batch_pcc(pred, target):
    p  = pred.flatten(1); t = target.flatten(1)
    vp = p - p.mean(1, keepdim=True)
    vt = t - t.mean(1, keepdim=True)
    num = (vp * vt).sum(1)
    den = (vp.pow(2).sum(1).sqrt() * vt.pow(2).sum(1).sqrt()).clamp(min=1e-8)
    return (num / den).clamp(-1, 1).mean()


def wpcc(pred_lin, target_lin):
    """
    [F2] Returns 0.0 (not nan) if there are no wet pixels in the batch.
    Safe to use in a loss term without nan-guarding at the call site.
    """
    wet = target_lin.flatten(1).max(1).values > WET_THRESH_LIN
    if not wet.any():
        return pred_lin.new_tensor(0.0)
    p = pred_lin[wet]; t = target_lin[wet]
    pcc = batch_pcc(p, t)
    # Extra nan guard — should never trigger but costs nothing
    if torch.isnan(pcc):
        return pred_lin.new_tensor(0.0)
    return pcc


def dry_hit_rate(pred_lin, target_lin):
    dry = target_lin.flatten(1).max(1).values < WET_THRESH_LIN
    if not dry.any():
        return pred_lin.new_tensor(1.0)
    pred_d = pred_lin[dry].flatten(1).max(1).values
    return (pred_d < DRY_MARGIN).float().mean()


def heavy_rmse(pred_lin, target_lin):
    wet_vals = target_lin[target_lin > WET_THRESH_LIN]
    if wet_vals.numel() < 10:
        return pred_lin.new_tensor(0.0)
    thr   = torch.quantile(wet_vals, 0.90)
    heavy = target_lin.flatten(1).max(1).values > thr
    if not heavy.any():
        return pred_lin.new_tensor(0.0)
    return F.mse_loss(pred_lin[heavy], target_lin[heavy]).sqrt()


# ================================================================
# EMA
# ================================================================

class EMA:
    def __init__(self, model, decay=0.9995, warmup=1000):
        self.decay  = decay; self.warmup = warmup; self.step = 0
        self.shadow  = {n: p.data.clone() for n, p in model.named_parameters()
                        if p.requires_grad}
        self._backup = None

    def _d(self):
        return 0.99 + min(self.step / max(self.warmup, 1), 1.0) * (self.decay - 0.99)

    def update(self, model):
        self.step += 1; d = self._d()
        with torch.no_grad():
            for n, p in model.named_parameters():
                if p.requires_grad:
                    self.shadow[n].mul_(d).add_(p.data, alpha=1-d)

    def apply(self, model):
        for n, p in model.named_parameters():
            if p.requires_grad and n in self.shadow:
                p.data.copy_(self.shadow[n])

    def backup(self, model):
        self._backup = {n: p.data.clone() for n, p in model.named_parameters()
                        if p.requires_grad}

    def restore(self, model):
        if not self._backup: return
        for n, p in model.named_parameters():
            if p.requires_grad and n in self._backup:
                p.data.copy_(self._backup[n])
        self._backup = None


# ================================================================
# TEMPORAL SEQUENCE BUILDER
# ================================================================

def build_seq(ds, indices, seq_len, dev):
    coarse_all = ds.coarse
    B = len(indices)
    C, H, W = coarse_all[0].shape
    seq = torch.zeros(B, seq_len, C, H, W, device=dev)
    for b, idx in enumerate(indices):
        for t in range(seq_len):
            src_idx = max(0, idx - (seq_len - t))
            seq[b, t] = coarse_all[src_idx].to(dev)
    return seq


# ================================================================
# [F4] SIGMA_DATA MEASUREMENT
# ================================================================

@torch.no_grad()
def measure_sigma_data(loader, model, dev, n_batches=30):
    """
    Compute std of (fine - pred) residuals over n_batches.
    Saved to checkpoint so Stage-2 picks it up automatically.
    """
    model.eval()
    residuals = []
    for i, b in enumerate(loader):
        if i >= n_batches: break
        fine = b["fine"].to(dev)[:, PRECIP_CH:PRECIP_CH+1]
        topo = b["topo"].to(dev)
        tf   = torch.stack([b["doy"], b["hour"]], 1).float().to(dev)
        xi   = b["coarse"].to(dev)
        pred = F.softplus(model(xi, topo=topo, global_features=tf), beta=5)
        residuals.append((fine - pred).flatten().cpu())
    all_res = torch.cat(residuals)
    sd = all_res.std().item()
    return max(sd, 0.01)


# ================================================================
# CHECKPOINT MANIFEST
# ================================================================

def update_manifest(manifest_path, ckpt_path, wpcc_val, max_keep=MAX_CKPTS_KEEP):
    if os.path.exists(manifest_path):
        with open(manifest_path) as f:
            manifest = json.load(f)
    else:
        manifest = {"checkpoints": []}

    manifest["checkpoints"].append({"path": ckpt_path, "wpcc": float(wpcc_val)})
    manifest["checkpoints"].sort(key=lambda x: x["wpcc"], reverse=True)
    kept    = manifest["checkpoints"][:max_keep]
    removed = manifest["checkpoints"][max_keep:]

    for e in removed:
        p = e["path"]
        if os.path.exists(p) and p not in (SAVE_PATH, LATEST_PATH):
            try: os.remove(p)
            except Exception: pass

    manifest["checkpoints"] = kept
    with open(manifest_path, "w") as f:
        json.dump(manifest, f, indent=2)


