# ================================================================
# TRAINING
def train():
    rank, ws, lr_, dev = setup_ddp()
    for p in [RF_PATH, ORO_PATH]:
        assert os.path.exists(p), f"Missing: {p}"

    os.makedirs(CKPT_DIR, exist_ok=True)
    ds = UpscaleDataset(RF_PATH, ORO_PATH, split="train", normalize=True, device="cpu")

    n = len(ds)
    trn = int(0.70 * n)
    van = int(0.10 * n)

    trl = DataLoader(Subset(ds, range(0, trn)), BATCH_SIZE,
                     shuffle=True, num_workers=8, pin_memory=True, drop_last=True)
    val = DataLoader(Subset(ds, range(trn, trn+van)), BATCH_SIZE,
                     shuffle=False, num_workers=4, pin_memory=True)

    if is_main(rank):
        print(f"[DATA] Train={trn} Val={van}")

    model_kwargs = dict(
        in_channels=1,
        out_channels=1,
        base_channels=96,
        channel_mult=(1, 2, 4),
        num_blocks=2,
        global_dim=2,
        dropout=0.0,
        dry_gate=False,
        cross_attn=True,   # model has cross_attn weights in checkpoint
        freq_attn=True,
        drop_path_rate=0.0,
    )

    if USE_TEMPORAL:
        model = TemporalCorrDiffRegressor(
            **model_kwargs,
            seq_len=SEQ_LEN, lstm_layers=LSTM_LAYERS, fine_size=128,
        ).to(dev)
    else:
        model = CorrDiffRegressor(**model_kwargs).to(dev)

    if ws > 1:
        model = torch.nn.parallel.DistributedDataParallel(
            model, device_ids=[lr_], find_unused_parameters=True
        )

    raw_model = model.module if ws > 1 else model
    ema = EMA(raw_model)

    start_epoch = 0
    best_wPCC = -1.0
    sigma_data = None

    # ── Resume from BEST ────────────────────────────────────────────
    rpath = SAVE_PATH if os.path.exists(SAVE_PATH) else LATEST_PATH
    if os.path.exists(rpath):
        if is_main(rank): print(f"[RESUME] {rpath}")
        ck2 = torch.load(rpath, map_location=dev)
        try:
            raw_model.load_state_dict(
                ck2.get("model_state_dict", ck2.get("ema_state_dict")))
        except RuntimeError as e:
            if is_main(rank): print(f" [WARN] state dict mismatch: {e}")
        if "ema_state_dict" in ck2:
            ema.shadow = {k: v.clone().to(dev) for k, v in ck2["ema_state_dict"].items()}
        start_epoch = ck2.get("epoch", 0) + 1
        best_wPCC = ck2.get("val_wpcc", -1.0)
        sigma_data = ck2.get("sigma_data", None)
        if is_main(rank):
            print(f" epoch={start_epoch} best_wPCC={best_wPCC:.4f}")
            if sigma_data: print(f" sigma_data={sigma_data:.6f}")

    # ── Freeze cross_attn, train everything else ─────────────────────
    if hasattr(raw_model, 'cross_attn_block'):
        for p in raw_model.cross_attn_block.parameters():
            p.requires_grad_(False)
        if is_main(rank): print("[INFO] cross_attn_block FROZEN")

    opt = AdamW(filter(lambda p: p.requires_grad, model.parameters()),
                lr=LR, weight_decay=1e-4, betas=(0.9, 0.999))
    scaler = GradScaler(device=dev.type, init_scale=256.0,
                        growth_interval=500, backoff_factor=0.5)
    sched = CosineAnnealingWarmRestarts(opt, T_0=75, T_mult=2, eta_min=LR * 0.01)

    if is_main(rank):
        np_ = sum(p.numel() for p in model.parameters() if p.requires_grad)
        print(f"[MODEL] {'Temporal' if USE_TEMPORAL else 'Plain'} regressor "
              f"{np_/1e6:.2f}M trainable params\n")
        hdr = f"{'Ep':>6} | {'MSE':>6} | {'wW':>5} | {'wM':>5} | {'wPCC_tr':>7} | {'wPCC_v':>7} | {'DHR':>5} | {'HRMSE':>6}"
        print(hdr); print("-" * len(hdr))

    for ep in range(start_epoch, EPOCHS):
        model.train()
        t0 = time.time()
        s_mse = s_wpcc = 0.0
        n_batch = 0
        n_skipped = 0

        w_mse, w_wpcc = loss_weights(ep)

        for bi, b in enumerate(trl):
            try:
                fine = b["fine"].to(dev)
                topo = b["topo"].to(dev)
                tf = torch.stack([b["doy"], b["hour"]], 1).float().to(dev)
                xi = b["coarse"].to(dev)

                fp = fine[:, PRECIP_CH:PRECIP_CH+1]
                fp_lin = torch.clamp(torch.expm1(fp.clamp(-5, 9)), 0, 1500.0)

                seq = None
                if USE_TEMPORAL:
                    if "idx" in b:
                        seq = build_seq(ds, b["idx"].tolist(), SEQ_LEN, dev)
                    else:
                        seq = torch.zeros(fp.shape[0], SEQ_LEN,
                                          xi.shape[1], xi.shape[2], xi.shape[3], device=dev)

                opt.zero_grad(set_to_none=True)

                with autocast(device_type=dev.type, enabled=True):
                    if USE_TEMPORAL:
                        pred_log = model(xi, topo=topo, global_features=tf, seq=seq)
                    else:
                        pred_log = model(xi, topo=topo, global_features=tf)

                    pred_lin = torch.clamp(torch.expm1(pred_log.clamp(-5, 9)), 0, 1500.0)
                    l_mse = mse_log1p(pred_log, fp)
                    w_val = wpcc(pred_lin, fp_lin)
                    loss = w_mse * l_mse + w_wpcc * (1.0 - w_val)

                if torch.isnan(loss) or torch.isinf(loss):
                    if is_main(rank):
                        print(f" [SKIP] ep={ep} bi={bi} loss=nan")
                    n_skipped += 1
                    continue

                scaler.scale(loss).backward()
                scaler.unscale_(opt)
                torch.nn.utils.clip_grad_norm_(model.parameters(), 2.0)

                prev_scale = scaler.get_scale()
                scaler.step(opt)
                scaler.update()

                if scaler.get_scale() < prev_scale:
                    n_skipped += 1

                ema.update(raw_model)

                with torch.no_grad():
                    if math.isfinite(l_mse.item()):
                        s_mse += l_mse.item()
                        s_wpcc += w_val.item()
                        n_batch += 1

            except Exception:
                if is_main(rank):
                    print(f"\n[ERROR] ep={ep} bi={bi}")
                    traceback.print_exc()
                raise

        sched.step()
        ni = 1.0 / max(n_batch, 1)
        te  = allreduce_mean(torch.tensor(s_mse  * ni, device=dev), ws).item()
        tw2 = allreduce_mean(torch.tensor(s_wpcc * ni, device=dev), ws).item()

        # ======================== VALIDATION ========================
        ema.backup(raw_model); ema.apply(raw_model)
        model.eval()

        vs = torch.tensor(0., device=dev)
        vd = torch.tensor(0., device=dev)
        vh = torch.tensor(0., device=dev)
        vn = torch.tensor(0, device=dev, dtype=torch.long)

        with torch.no_grad():
            for bi, b in enumerate(val):
                if bi >= 30: break
                fine_v = b["fine"].to(dev)
                topo_v = b["topo"].to(dev)
                tf_v = torch.stack([b["doy"], b["hour"]], 1).float().to(dev)
                xi_v = b["coarse"].to(dev)

                fp_v  = fine_v[:, PRECIP_CH:PRECIP_CH+1]
                fpl_v = torch.clamp(torch.expm1(fp_v.clamp(-5, 9)), 0, 1500.0)

                seq_v = None
                if USE_TEMPORAL:
                    if "idx" in b:
                        seq_v = build_seq(ds, b["idx"].tolist(), SEQ_LEN, dev)
                    else:
                        seq_v = torch.zeros(fp_v.shape[0], SEQ_LEN,
                                            xi_v.shape[1], xi_v.shape[2], xi_v.shape[3], device=dev)
                    pred_v = model(xi_v, topo=topo_v, global_features=tf_v, seq=seq_v)
                else:
                    pred_v = model(xi_v, topo=topo_v, global_features=tf_v)

                pl_v = torch.clamp(torch.expm1(pred_v.clamp(-5, 9)), 0, 1500.0)

                vs += wpcc(pl_v, fpl_v)
                vd += dry_hit_rate(pl_v, fpl_v)
                vh += heavy_rmse(pl_v, fpl_v)
                vn += 1

        if ws > 1 and dist.is_initialized():
            for t_ in [vs, vd, vh, vn]:
                dist.all_reduce(t_, op=dist.ReduceOp.SUM)

        vw   = (vs / vn.clamp(min=1)).item()
        vdhr = (vd / vn.clamp(min=1)).item()
        vhrm = (vh / vn.clamp(min=1)).item()

        ema.restore(raw_model)
        el = time.time() - t0

        if sigma_data is None and is_main(rank):
            ema.backup(raw_model); ema.apply(raw_model)
            model.eval()
            sigma_data = measure_sigma_data(trl, raw_model, dev)
            ema.restore(raw_model)
            model.train()
            print(f" [SIGMA_DATA] measured = {sigma_data:.6f}")

        if is_main(rank) and ep % LOG_EVERY == 0:
            skip_info = f" skip={n_skipped}" if n_skipped > 0 else ""
            print(f"{ep:>6} | {te:>6.3f} | {w_wpcc:>5.3f} | {w_mse:>5.3f} | "
                  f"{tw2:>7.4f} | {vw:>7.4f} | {vdhr:>5.3f} | {vhrm:>6.3f}"
                  f" [{el:.0f}s]{skip_info}")
            print(f" [INFO] Skipped {n_skipped} batches this epoch | Current LR: {opt.param_groups[0]['lr']:.2e}")

        if is_main(rank):
            ckpt = {
                "epoch":               ep,
                "model_state_dict":    raw_model.state_dict(),
                "ema_state_dict":      {k: v.cpu() for k, v in ema.shadow.items()},
                "optimizer_state_dict": opt.state_dict(),
                "val_wpcc":            vw,
                "use_temporal":        USE_TEMPORAL,
                "seq_len":             SEQ_LEN,
                "sigma_data":          sigma_data,
            }
            torch.save(ckpt, LATEST_PATH)

            if vw > best_wPCC:
                best_wPCC = vw
                ema.backup(raw_model); ema.apply(raw_model)
                best = dict(ckpt)
                best["model_state_dict"] = raw_model.state_dict()
                best["ema_state_dict"]   = raw_model.state_dict()
                torch.save(best, SAVE_PATH)
                ema.restore(raw_model)
                print(f" ★ NEW BEST wPCC={vw:.4f} → {SAVE_PATH}")

            if ep > 0 and ep % CKPT_SAVE_EVERY == 0 and vw > 0.0:
                ep_path = os.path.join(CKPT_DIR, f"regressor_ep{ep:05d}.pth")
                ema.backup(raw_model); ema.apply(raw_model)
                ep_ckpt = dict(ckpt)
                ep_ckpt["model_state_dict"] = raw_model.state_dict()
                ep_ckpt["ema_state_dict"]   = raw_model.state_dict()
                torch.save(ep_ckpt, ep_path)
                ema.restore(raw_model)
                update_manifest(MANIFEST, ep_path, vw, MAX_CKPTS_KEEP)
                if os.path.exists(SAVE_PATH):
                    update_manifest(MANIFEST, SAVE_PATH, best_wPCC, MAX_CKPTS_KEEP)

    if ws > 1 and dist.is_initialized():
        dist.destroy_process_group()


if __name__ == "__main__":
    train()


